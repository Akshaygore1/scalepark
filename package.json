{
  "name": "infraplay",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "typescript": "^6",
      "@types/node": "^22.13.14",
      "@cloudflare/workers-types": "^4.20260702.1",
      "hono": "^4.12.27",
      "@trpc/server": "^11.18.0",
      "better-auth": "1.6.23",
      "alchemy": "^0.93.12",
      "lucide-react": "^1.23.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "sonner": "^2.0.7",
      "@trpc/client": "^11.18.0",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.3.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "vp run -r dev",
    "build": "vp run -r build",
    "check-types": "vp run -r check-types",
    "check": "vp check && vp run -r check-types",
    "lint": "vp lint",
    "format": "vp fmt",
    "staged": "vp staged",
    "hooks:setup": "vp config",
    "dev:web": "vp run --filter web dev",
    "dev:server": "vp run --filter server dev",
    "db:generate": "vp run --filter @infraplay/db db:generate",
    "deploy": "vp run --filter @infraplay/infra deploy",
    "destroy": "vp run --filter @infraplay/infra destroy"
  },
  "dependencies": {
    "@infraplay/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@infraplay/config": "workspace:*",
    "@types/node": "catalog:",
    "rolldown": "1.1.4",
    "typescript": "catalog:",
    "vite-plus": "0.2.2"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2"
  },
  "packageManager": "bun@1.3.2"
}
